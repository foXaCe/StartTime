{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(deps)",
    ":dependencyDashboard",
    "group:allNonMajor"
  ],
  "timezone": "Europe/Paris",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "assignees": ["foXaCe"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Auto-merge patch, pin and digest updates",
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "description": "Auto-merge GitHub Actions minor/patch",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "github-actions"]
    },
    {
      "description": "Major updates need review",
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major", "needs-review"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Group lint & format tooling",
      "matchPackageNames": ["ruff", "mypy"],
      "groupName": "lint & format tools"
    }
  ]
}
